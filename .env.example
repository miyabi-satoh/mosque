DATABASE_CLIENT=postgresql
DATABASE_HOST=localhost
DATABASE_NAME=mosque
DATABASE_USERNAME=mosque
DATABASE_PORT=5432
DATABASE_PASSWORD=password
# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"

BACKEND_CORS_ORIGINS=["http://localhost", "http://localhost:3000"]
PROJECT_NAME=mosque
SECRET_KEY=<openssl rand -hex 32>

USERS_OPEN_REGISTRATION=False

SENTRY_DSN=

# strapi
HOST=0.0.0.0
PORT=1337
APP_KEYS=$(openssl rand -base64 32)
API_TOKEN_SALT=$(openssl rand -base64 32)
ADMIN_JWT_SECRET=$(openssl rand -base64 32)
JWT_SECRET=$(openssl rand -base64 32)
NODE_ENV=development

# frontend
PUBLIC_SERVER_NAME=localhost
PUBLIC_SERVER_HOST=http://localhost
PUBLIC_BACKEND_HOST=http://localhost/api/v1
PUBLIC_STRAPI_HOST=http://localhost/strapi
